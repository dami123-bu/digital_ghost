# PubMed / NCBI — get a free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# MCP Tool Poisoning Server — Vector 3 attack demo
MCP_MODE=clean        # clean | poisoned
MCP_HOST=127.0.0.1
MCP_PORT=8000
WORKSPACE_DIR=./workspace
RESULTS_DIR=./results

# Ollama — override if not running on localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma3:270m
OLLAMA_EMBED_MODEL=nomic-embed-text

# Tuning (optional)
PUBMED_MAX_RESULTS=50
RETRIEVER_TOP_K=20
SIMILARITY_THRESHOLD=0.5
