# PubMed / NCBI — get a free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# MCP Tool Poisoning Server — Vector 3 attack demo
# NOTE: WORKSPACE_DIR and RESULTS_DIR are read by src/pharma_help/mcp/config.py, not root config.py
MCP_MODE=clean        # clean | poisoned
MCP_HOST=127.0.0.1
MCP_PORT=8000
WORKSPACE_DIR=./workspace
RESULTS_DIR=./results

# LLM Provider — which model backs the agent (used by src/pharma_help/agents/llm_factory.py)
LLM_PROVIDER=ollama   # ollama | gemini | claude

# Ollama — override if not running on localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
# Windows (Ryzen AI Max+ 128 GB): use qwen2.5:32b instead
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini (optional — free tier; get a key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Backend behaviour
FORCE_RAG=true        # always prepend RAG context; needed for smaller models

# Tuning (optional)
PUBMED_MAX_RESULTS=50
RETRIEVER_TOP_K=20
SIMILARITY_THRESHOLD=0.5
