# PubMed / NCBI — get a free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Chainlit UI — moved off 8000 so the MCP main_server can use it
CHAINLIT_PORT=8010

# MCP Tool Poisoning Server — Vector 3 attack demo
# MCP_MODE: clean | poisoned
MCP_MODE=clean
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Ollama — override if not running on localhost
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma3:270m
OLLAMA_EMBED_MODEL=embeddinggemma

# Tuning (optional)
PUBMED_MAX_RESULTS=50
RETRIEVER_TOP_K=20
SIMILARITY_THRESHOLD=0.5

# Path overrides (optional — defaults resolve relative to project root)
# PHARMA_DATA_DIR=data
# WORKSPACE_DIR=workspace
# RESULTS_DIR=results
# CHROMA_DIR=data/chroma
# DRUGS_FILE=data/drugs.txt
